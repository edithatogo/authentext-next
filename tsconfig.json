{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["*.js", "scripts/**/*.js", "test/**/*.js", "skills/**/*.js"],
  "exclude": ["node_modules", "dist"]
}
